            <!-- Hero Section -->
            <trans-unit id="hero.tagline">
                <source>Your success is our mission</source>
                <target>Ihr Erfolg ist unsere Mission</target>
            </trans-unit>
            <trans-unit id="hero.headline">
                <source>Professional Solutions for Your Business</source>
                <target>Professionelle Lösungen für Ihr Unternehmen</target>
            </trans-unit>
            <trans-unit id="hero.subline">
                <source>We deliver innovative strategies and tailor-made solutions that drive your company forward. Reliable, experienced, results-oriented.</source>
                <target>Wir liefern innovative Strategien und maßgeschneiderte Lösungen, die Ihr Unternehmen voranbringen. Zuverlässig, erfahren, ergebnisorientiert.</target>
            </trans-unit>
            <trans-unit id="hero.cta.primary">
                <source>Discover Our Services</source>
                <target>Unsere Leistungen entdecken</target>
            </trans-unit>
            <trans-unit id="hero.cta.secondary">
                <source>Contact Us</source>
                <target>Kontakt aufnehmen</target>
            </trans-unit>

            <!-- About Section -->
            <trans-unit id="about.label">
                <source>About Us</source>
                <target>Über uns</target>
            </trans-unit>
            <trans-unit id="about.headline">
                <source>Expertise You Can Count On</source>
                <target>Kompetenz, auf die Sie zählen können</target>
            </trans-unit>
            <trans-unit id="about.text1">
                <source>With over 15 years of experience, Merkur has established itself as a trusted partner for businesses seeking sustainable growth and innovative solutions. Our interdisciplinary team combines deep industry knowledge with fresh perspectives.</source>
                <target>Mit über 15 Jahren Erfahrung hat sich Merkur als vertrauenswürdiger Partner für Unternehmen etabliert, die nachhaltiges Wachstum und innovative Lösungen anstreben. Unser interdisziplinäres Team verbindet tiefes Branchenwissen mit frischen Perspektiven.</target>
            </trans-unit>
            <trans-unit id="about.text2">
                <source>We believe in building long-term partnerships based on trust, transparency, and measurable results. Your goals become our goals – and we work tirelessly to achieve them.</source>
                <target>Wir glauben an langfristige Partnerschaften, die auf Vertrauen, Transparenz und messbaren Ergebnissen basieren. Ihre Ziele werden zu unseren Zielen – und wir arbeiten unermüdlich daran, sie zu erreichen.</target>
            </trans-unit>
            <trans-unit id="about.stat1.value">
                <source>15+</source>
                <target>15+</target>
            </trans-unit>
            <trans-unit id="about.stat1.label">
                <source>Years Experience</source>
                <target>Jahre Erfahrung</target>
            </trans-unit>
            <trans-unit id="about.stat2.value">
                <source>300+</source>
                <target>300+</target>
            </trans-unit>
            <trans-unit id="about.stat2.label">
                <source>Happy Clients</source>
                <target>Zufriedene Kunden</target>
            </trans-unit>
            <trans-unit id="about.stat3.value">
                <source>98%</source>
                <target>98%</target>
            </trans-unit>
            <trans-unit id="about.stat3.label">
                <source>Satisfaction Rate</source>
                <target>Zufriedenheitsrate</target>
            </trans-unit>
            <trans-unit id="about.cta">
                <source>Learn More About Us</source>
                <target>Mehr über uns erfahren</target>
            </trans-unit>

            <!-- Services Section -->
            <trans-unit id="services.label">
                <source>Our Services</source>
                <target>Unsere Leistungen</target>
            </trans-unit>
            <trans-unit id="services.headline">
                <source>What We Offer</source>
                <target>Was wir bieten</target>
            </trans-unit>
            <trans-unit id="services.subline">
                <source>Comprehensive solutions tailored to your unique business needs</source>
                <target>Umfassende Lösungen, maßgeschneidert für Ihre individuellen Geschäftsanforderungen</target>
            </trans-unit>
            <trans-unit id="services.1.title">
                <source>Strategy &amp; Consulting</source>
                <target>Strategie &amp; Beratung</target>
            </trans-unit>
            <trans-unit id="services.1.description">
                <source>Data-driven strategies and expert consulting to help you navigate complex business challenges and seize new opportunities.</source>
                <target>Datengestützte Strategien und Expertenberatung, die Ihnen helfen, komplexe Geschäftsherausforderungen zu meistern und neue Chancen zu nutzen.</target>
            </trans-unit>
            <trans-unit id="services.2.title">
                <source>Digital Transformation</source>
                <target>Digitale Transformation</target>
            </trans-unit>
            <trans-unit id="services.2.description">
                <source>Modernize your business processes with cutting-edge digital solutions, from workflow automation to cloud integration.</source>
                <target>Modernisieren Sie Ihre Geschäftsprozesse mit modernsten digitalen Lösungen – von der Workflow-Automatisierung bis zur Cloud-Integration.</target>
            </trans-unit>
            <trans-unit id="services.3.title">
                <source>Brand &amp; Marketing</source>
                <target>Marke &amp; Marketing</target>
            </trans-unit>
            <trans-unit id="services.3.description">
                <source>Build a compelling brand identity and effective marketing campaigns that resonate with your target audience.</source>
                <target>Entwickeln Sie eine überzeugende Markenidentität und effektive Marketingkampagnen, die Ihre Zielgruppe ansprechen.</target>
            </trans-unit>
            <trans-unit id="services.4.title">
                <source>Technology Solutions</source>
                <target>Technologielösungen</target>
            </trans-unit>
            <trans-unit id="services.4.description">
                <source>Custom software development, system integration and IT infrastructure to power your business growth.</source>
                <target>Individuelle Softwareentwicklung, Systemintegration und IT-Infrastruktur für Ihr Unternehmenswachstum.</target>
            </trans-unit>
            <trans-unit id="services.5.title">
                <source>Project Management</source>
                <target>Projektmanagement</target>
            </trans-unit>
            <trans-unit id="services.5.description">
                <source>End-to-end project delivery with agile methodologies, ensuring on-time, on-budget results every time.</source>
                <target>Ganzheitliche Projektabwicklung mit agilen Methoden, die pünktliche und budgetkonforme Ergebnisse gewährleisten.</target>
            </trans-unit>
            <trans-unit id="services.6.title">
                <source>Training &amp; Development</source>
                <target>Training &amp; Entwicklung</target>
            </trans-unit>
            <trans-unit id="services.6.description">
                <source>Empower your team with customized training programs and workshops that build lasting skills and capabilities.</source>
                <target>Stärken Sie Ihr Team mit maßgeschneiderten Schulungsprogrammen und Workshops, die nachhaltige Kompetenzen aufbauen.</target>
            </trans-unit>
            <trans-unit id="services.cta">
                <source>Learn More</source>
                <target>Mehr erfahren</target>
            </trans-unit>

